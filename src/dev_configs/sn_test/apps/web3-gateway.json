{
    "name": "web3-gateway",
    "version": "latest",
    "directories": {
        "source": "/opt/web3-gateway",
        "target": "/opt/web3-gateway",
        "source_bin": "/opt/web3-gateway/web3_gateway",
        "target_bin": "/opt/web3-gateway/web3_gateway"
    },
    "commands": {
      "build": [
        "cd {{system.base_dir}}/src && uv run ./build.py aarch64"
      ],
      "build_all": [
        "cd {{system.base_dir}}/src && uv run ./build.py aarch64",
        "cd {{system.base_dir}}/src && uv run ./make_sn_config.py sn_server"
      ],
      "install": [
        "sudo chmod +x /opt/web3-gateway/web3_gateway"
      ],
      "start": ["sudo uv run /opt/web3-gateway/start.py"],
      "stop": ["sudo uv run /opt/web3-gateway/stop.py"]
    }
  }
